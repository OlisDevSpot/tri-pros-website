# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ignore projects photos
/public/portfolio-photos/projects/

# Playwright MCP auth session (live super-admin credential — never commit)
/.playwright/
# Playwright MCP run artifacts (console logs, page snapshots)
/.playwright-mcp/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.ci
/secrets

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Git worktrees
.worktrees/
.superpowers/

# Local MCP overrides (holds project-scoped API tokens — never commit)
.mcp.local.json

# ZIP→county build input for generate-service-area-zips.ts (not runtime data)
scripts/data/
