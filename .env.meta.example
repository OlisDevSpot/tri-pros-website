# Meta Marketing API credentials
# Copy this file to .env.meta and fill in real values.
# .env.meta is gitignored — never commit real credentials.
#
# Where to get these values:
#   META_APP_ID         — Meta Developer Console → Your App → App ID
#   META_ACCESS_TOKEN   — Business Manager → System Users → Generate Token
#                         (use a System User token, not a personal user token — it's non-expiring)
#   META_AD_ACCOUNT_ID  — Business Manager → Ad Accounts → Account ID, prefixed with act_
#   META_PAGE_ID        — Your Facebook Page → About → Page ID

META_APP_ID=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_
META_PAGE_ID=
